generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth.js models ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  plan          String    @default("free") // free | pro | team | enterprise
  accounts      Account[]
  scans         Scan[]
  payments      Payment[]
  apiKeys       ApiKey[]
  memberships   OrgMember[]
  auditLogs     AuditLog[]
  notifications NotificationSetting?
  agents        Agent[]
  agentTeams    AgentTeam[]
  llmSettings   Json?     // { provider, model, think, apiKeys: { DEEPSEEK_API_KEY, OPENAI_API_KEY, ... } }
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ── Organizations & Teams ────────────────────────────────

model Org {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  plan        String      @default("team") // team | enterprise
  members     OrgMember[]
  scans       Scan[]
  repos       MonitoredRepo[]
  policies    Policy[]
  webhooks    Webhook[]
  auditLogs   AuditLog[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrgMember {
  id     String @id @default(cuid())
  orgId  String
  userId String
  role   String @default("member") // owner | admin | member | viewer
  org    Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

// ── Scans ───────────────────────────────────────────────

model Scan {
  id          String    @id @default(cuid())
  userId      String
  orgId       String?
  repo        String          // e.g. "owner/repo" or URL
  branch      String    @default("main")
  method      String    @default("github") // github | url | upload | scheduled | api | github-app
  trigger     String    @default("manual") // manual | scheduled | webhook | pr | api
  status      String    @default("pending") // pending | running | done | failed
  score       Int?
  grade       String?
  findings    Int       @default(0)
  secrets     Int       @default(0)
  vulns       Int       @default(0)
  cves        Int       @default(0)
  duration    Float?          // seconds
  report      Json?           // full scan results
  options     Json?           // scan options
  aiProvider  String?         // provider used for AI analysis (deepseek-flash, openai, kimi, etc.)
  prNumber    Int?            // GitHub PR number (if triggered by PR)
  prCommented Boolean   @default(false)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  org         Org?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([repo, createdAt(sort: Desc)])
}

// ── Monitored Repos & Scheduled Scans ────────────────────

model MonitoredRepo {
  id          String    @id @default(cuid())
  orgId       String?
  userId      String
  repo        String          // owner/repo
  branch      String    @default("main")
  schedule    String?         // cron expression: "0 9 * * 1" = every Monday 9am
  lastScanAt  DateTime?
  lastScore   Int?
  lastGrade   String?
  enabled     Boolean   @default(true)
  options     Json?           // default scan options
  org         Org?      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, repo])
  @@index([orgId])
  @@index([schedule])
}

// ── Security Policies ────────────────────────────────────

model Policy {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  description String?
  rules       Json           // array of policy rules
  enforcement String   @default("warn") // warn | block
  enabled     Boolean  @default(true)
  org         Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
}

// ── API Keys ─────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  keyHash     String    @unique   // SHA-256 hash of the key
  keyPrefix   String              // first 8 chars for display: "sk_live_aBcD..."
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  scopes      Json      @default("[]") // ["scan:create", "scan:read", "report:read"]
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ── Webhooks & Notifications ─────────────────────────────

model Webhook {
  id          String   @id @default(cuid())
  orgId       String?
  userId      String
  url         String
  events      Json     @default("[\"scan.completed\"]") // scan.completed, scan.failed, finding.critical
  secret      String          // HMAC signing secret
  enabled     Boolean  @default(true)
  lastStatus  Int?            // last HTTP status code
  org         Org?     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
}

model NotificationSetting {
  id                   String  @id @default(cuid())
  userId               String  @unique
  emailOnComplete      Boolean @default(true)
  emailOnCritical      Boolean @default(true)
  emailDigest          String  @default("weekly") // off | daily | weekly
  slackWebhookUrl      String?
  slackOnComplete      Boolean @default(false)
  slackOnCritical      Boolean @default(true)
  // Agent-specific alerts
  agentSlackOnCritical Boolean @default(true)
  agentSlackOnHigh     Boolean @default(false)
  agentEmailOnCritical Boolean @default(true)
  // GitHub integration
  githubToken          String? // Personal access token for creating issues
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── GitHub App ───────────────────────────────────────────

model GitHubInstallation {
  id               String   @id @default(cuid())
  installationId   Int      @unique
  accountLogin     String         // org or user login
  accountType      String         // Organization | User
  targetType       String         // all | selected
  repositorySelection String @default("all")
  permissions      Json?
  events           Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── PR Guardian ────────────────────────────────────────────

model PRGuardianRun {
  id            String   @id @default(cuid())
  userId        String
  orgId         String?
  repo          String          // owner/repo
  prNumber      Int
  prTitle       String?
  prBranch      String          // head branch
  baseBranch    String          // base branch
  status        String   @default("watching")
  // watching | analyzing | diagnosing | fixing | verifying | merging | merged | failed | blocked
  scanId        String?         // link to the Scan that triggered this
  ciRunId       Int?            // GitHub Actions run ID being monitored
  ciStatus      String?         // pending | success | failure | cancelled
  failureType   String?         // shipsafe | test | build | lint | unknown
  failureLogs   String?  @db.Text
  diagnosis     Json?           // { findings: [...], falsePositives: [...], realIssues: [...] }
  fixCommitSha  String?
  fixSummary    String?
  mergeStrategy String?         // squash | merge | rebase
  mergeSha      String?
  attempts      Int      @default(0)
  timeline      Json     @default("[]") // array of { timestamp, event, detail }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([repo, prNumber])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
}

model GuardianConfig {
  id                    String   @id @default(cuid())
  userId                String
  orgId                 String?
  repo                  String          // owner/repo or "*" for default
  enabled               Boolean  @default(true)
  autoFixFalsePositives Boolean  @default(true)
  autoFixRealIssues     Boolean  @default(false)
  autoMerge             Boolean  @default(false)
  mergeStrategy         String   @default("squash") // squash | merge | rebase
  requireApproval       Boolean  @default(true)
  minScoreToMerge       Int      @default(80)
  maxAttempts           Int      @default(3)
  fixCategories         Json     @default("[\"secrets\"]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, repo])
  @@index([orgId])
}

// ── Hermes Agent Studio ──────────────────────────────────

model Agent {
  id              String            @id @default(cuid())
  userId          String
  orgId           String?
  name            String
  slug            String            @unique
  description     String?
  tools           Json              @default("[]")    // [{ name: string, sourceUrl?: string }]
  memoryProvider  String            @default("builtin") // builtin | honcho | hindsight | mem0 | none
  maxDepth        Int               @default(2)
  skills          Json              @default("[]")
  envVars         Json              @default("{}")    // { KEY: "value" }
  ciProvider      String            @default("none")  // github | gitlab | none
  status          String            @default("draft") // draft | deployed | stopped | failed
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployments     Deployment[]
  triggers        Trigger[]
  findings        Finding[]
  teamMemberships AgentTeamMember[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([orgId])
}

model Finding {
  id          String   @id @default(cuid())
  agentId     String
  runId       String
  severity    String   // critical | high | medium | low | info
  title       String
  location    String?
  cve         String?
  remediation String?  @db.Text
  status      String   @default("open") // open | acknowledged | fixed | false_positive
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  run         AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId, createdAt(sort: Desc)])
  @@index([runId])
  @@index([severity, status])
}

model Trigger {
  id          String    @id @default(cuid())
  agentId     String
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type        String    // "webhook" | "cron"
  label       String    @default("")
  secret      String    // Bearer token for webhook auth
  cronExpr    String?   // cron expression (cron type only)
  promptTpl   String    @default("You have been triggered. Here is the event context:\n\n{payload}")
  enabled     Boolean   @default(true)
  lastFiredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([agentId])
}

model Deployment {
  id            String     @id @default(cuid())
  agentId       String
  version       Int        @default(1)
  status        String     @default("pending") // pending | running | stopped | failed
  containerId   String?
  port          Int?
  subdomain     String?
  deployLog     String?    @db.Text
  securityScore Int?
  agent         Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  runs          AgentRun[]
  startedAt     DateTime?
  stoppedAt     DateTime?
  createdAt     DateTime   @default(now())

  @@index([agentId, createdAt(sort: Desc)])
}

model AgentRun {
  id           String        @id @default(cuid())
  deploymentId String
  triggerId    String?       // set when fired by a Trigger
  teamRunId    String?       // set when part of a team run
  parentRunId  String?       // set when spawned by lead agent
  role         String?       // role in team: lead | pen_tester | red_team | secrets | cve_analyst | custom
  tokensUsed   Int?
  status       String        @default("running") // running | completed | error
  deployment   Deployment    @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  teamRun      TeamRun?      @relation(fields: [teamRunId], references: [id], onDelete: SetNull)
  parentRun    AgentRun?     @relation("RunTree", fields: [parentRunId], references: [id], onDelete: SetNull)
  childRuns    AgentRun[]    @relation("RunTree")
  messages     ChatMessage[]
  findings     Finding[]
  startedAt    DateTime      @default(now())
  completedAt  DateTime?

  @@index([deploymentId, startedAt(sort: Desc)])
  @@index([teamRunId])
  @@index([parentRunId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  runId      String
  role       String   // user | assistant
  content    String   @db.Text
  toolCalls  Json?    // [{ tool, args, result }] — tool calls made during this message
  tokensUsed Int?
  run        AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([runId, createdAt])
}

// ── Agent Teams ─────────────────────────────────────────

model AgentTeam {
  id          String            @id @default(cuid())
  userId      String
  orgId       String?
  name        String
  description String?
  members     AgentTeamMember[]
  runs        TeamRun[]
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([orgId])
}

model AgentTeamMember {
  id      String    @id @default(cuid())
  teamId  String
  agentId String
  role    String    // lead | pen_tester | red_team | secrets | cve_analyst | custom
  label   String?   // optional custom display label
  order   Int       @default(0)
  team    AgentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agent   Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([teamId, agentId])
  @@index([teamId])
  @@index([agentId])
}

model TeamRun {
  id          String     @id @default(cuid())
  teamId      String
  userId      String
  target      String     // what's being analyzed (repo, description, task)
  status      String     @default("running") // running | completed | error
  phase       String     @default("planning") // planning | delegating | synthesizing | done
  report      String?    @db.Text
  aiProvider  String?    // provider used (deepseek-flash, openai, kimi, etc.)
  agentRuns   AgentRun[]
  team        AgentTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  startedAt   DateTime   @default(now())
  completedAt DateTime?

  @@index([teamId, startedAt(sort: Desc)])
  @@index([userId, startedAt(sort: Desc)])
}

// ── Payments ────────────────────────────────────────────

model Payment {
  id                String   @id @default(cuid())
  userId            String
  stripeSessionId   String   @unique
  stripePaymentId   String?
  plan              String        // pro | team
  amount            Int           // cents
  currency          String   @default("usd")
  status            String   @default("pending") // pending | paid | failed | refunded
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@index([userId])
}

// ── Audit Log ────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  orgId     String?
  action    String         // scan.created, member.invited, policy.updated, settings.changed, etc.
  target    String?        // what was acted on (scan ID, user ID, repo name, etc.)
  meta      Json?          // additional context
  ip        String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  org       Org?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([orgId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

// ── Shared Reports (CLI share command) ──────────────────

model SharedReport {
  token     String   @id @default(cuid())
  score     Int?
  grade     String?
  repo      String?
  findings  Int      @default(0)
  report    Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
