# ship-safe ignore file
# Same syntax as .gitignore — one glob per line, # for comments.
#
# Files listed here are excluded from all ship-safe scans.
# Use this to suppress known false positives in your project.

# The pattern definition file contains pattern strings in description text.
# It is scanned and maintained by the ship-safe team — safe to exclude.
cli/utils/patterns.js

# Agent files contain regex patterns and fix suggestions that reference
# dangerous functions (eval, exec, pickle, etc.) — these are detection
# rules, not actual usage. Safe to exclude.
cli/agents/

# LLM provider makes HTTP requests by design (not SSRF)
cli/providers/

# AI defense patterns file contains intentional prompt injection test data
ai-defense/

# Documentation and example files intentionally contain dangerous patterns
snippets/
docs/
*.md

# Website source — Astro components may contain inline HTML examples (XSS patterns)
website/

# Generated HTML reports contain finding descriptions with code patterns
ship-safe-report.html
*.report.html

# Unit test fixtures — every test file intentionally contains vulnerable patterns
# to verify that the scanner detects them correctly. Scanning them would produce
# hundreds of expected findings by design.
cli/__tests__/

# Article assets contain intentional demo code showing vulnerable patterns
# for educational purposes in blog posts and documentation.
article-assets/
marketing/

# Blog post content — TypeScript data file containing example credentials,
# code snippets, and connection strings used in blog post copy. Not real credentials.
webapp/data/blog.ts

# The webapp is a Next.js app deployed on Vercel and audited by its own pipeline.
# Excluding it from the CLI self-scan keeps CI focused on the CLI package itself.
webapp/
